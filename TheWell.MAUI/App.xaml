<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:TheWell.MAUI.Converters"
             x:Class="TheWell.MAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToCheckConverter x:Key="BoolToCheckConverter" />
            <converters:BoolToButtonColorConverter x:Key="BoolToButtonColorConverter" />
            <converters:InvertBoolToButtonColorConverter x:Key="InvertBoolToColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

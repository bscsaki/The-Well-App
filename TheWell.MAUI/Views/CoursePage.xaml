<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TheWell.MAUI.ViewModels"
             x:Class="TheWell.MAUI.Views.CoursePage"
             x:DataType="vm:CourseViewModel"
             Title="Course">

    <Grid>

        <!-- ══════════════════════════════════════
             WEEK LIST VIEW (default)
             ══════════════════════════════════════ -->
        <RefreshView IsVisible="{Binding ShowingDetail, Converter={StaticResource InvertBoolConverter}}"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="12">

                    <Label Text="Course Weeks" FontSize="22" FontAttributes="Bold"
                           TextColor="#1A6B8A" Margin="0,8,0,4" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="#1A6B8A" />

                    <!-- Course not started message -->
                    <Frame IsVisible="{Binding CourseNotStarted}"
                           BackgroundColor="#FFF8E1" CornerRadius="12" Padding="20" HasShadow="False">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="Course Has Not Started Yet" FontSize="18"
                                   FontAttributes="Bold" TextColor="#E67E22" HorizontalOptions="Center" />
                            <Label Text="Your instructor will unlock course weeks when the programme begins."
                                   FontSize="14" TextColor="#888" HorizontalOptions="Center"
                                   LineBreakMode="WordWrap" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Label Text="{Binding ErrorMessage}" TextColor="Red"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- Week cards -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Weeks}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:WeekItem">
                                <Frame Padding="16" CornerRadius="12" HasShadow="True"
                                       BackgroundColor="{Binding CardColor}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Label}" FontSize="15" FontAttributes="Bold"
                                                   TextColor="{Binding TextColor}" />
                                            <Label Text="{Binding SubLabel}" FontSize="12"
                                                   TextColor="{Binding TextColor}" Opacity="0.85"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding LockStatus}"
                                               FontSize="11" VerticalOptions="Center"
                                               TextColor="{Binding TextColor}" Opacity="0.7"
                                               Margin="8,0,0,0" />
                                    </Grid>
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CourseViewModel}}, Path=OpenWeekCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Label Text="Locked weeks will be unlocked by your instructor."
                           FontSize="12" TextColor="#888" HorizontalOptions="Center"
                           Margin="0,8,0,0" />

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ══════════════════════════════════════
             WEEK DETAIL VIEW
             ══════════════════════════════════════ -->
        <Grid IsVisible="{Binding ShowingDetail}" RowDefinitions="Auto,*">

            <!-- Detail header bar with back -->
            <Grid Grid.Row="0" BackgroundColor="#1A6B8A" Padding="4,8" ColumnDefinitions="Auto,*">
                <ImageButton Grid.Column="0"
                             Command="{Binding BackToListCommand}"
                             Source="arrow_back.png"
                             HeightRequest="28" WidthRequest="28"
                             Padding="8"
                             BackgroundColor="Transparent"
                             VerticalOptions="Center" />
                <Label Grid.Column="1" Text="{Binding DetailTitle}"
                       FontSize="15" FontAttributes="Bold" TextColor="White"
                       VerticalOptions="Center" Margin="4,0,16,0"
                       LineBreakMode="TailTruncation" />
            </Grid>

            <!-- Detail content -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20" Spacing="16">

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="#1A6B8A" />

                    <Label Text="{Binding ErrorMessage}" TextColor="Red"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

                    <VerticalStackLayout IsVisible="{Binding HasSelectedContent}" Spacing="12">

                        <Label Text="{Binding SelectedContent.ModuleTitle}"
                               FontSize="20" FontAttributes="Bold" TextColor="#1A6B8A" />

                        <BoxView HeightRequest="1" BackgroundColor="#DDD" />

                        <Label Text="This Week's Message" FontAttributes="Bold" TextColor="#1A6B8A" />
                        <Label Text="{Binding SelectedContent.MotivationalMessage}"
                               FontSize="15" LineBreakMode="WordWrap" />

                        <BoxView HeightRequest="1" BackgroundColor="#DDD" />

                        <Label Text="Course Material" FontAttributes="Bold" TextColor="#1A6B8A" />
                        <WebView x:Name="MaterialWebView"
                                 HeightRequest="600"
                                 VerticalOptions="FillAndExpand" />

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>
